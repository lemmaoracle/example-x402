# ── Worker (set in Cloudflare dashboard or wrangler secret) ──────────
# Your wallet address to receive x402 micropayments
PAY_TO_ADDRESS=0xYourWalletAddressHere

# Lemma API base URL
LEMMA_API_BASE=https://workers.lemma.workers.dev

# Lemma API key (if required)
# LEMMA_API_KEY=

# ── Artifact Registration (scripts/register-lemma-artifacts.mjs) ─────
# Pinata IPFS credentials
# PINATA_API_KEY=
# PINATA_SECRET_API_KEY=

# On-chain Groth16 verifier contract (Base Sepolia)
# VERIFIER_CONTRACT=0x

# ── Agent ────────────────────────────────────────────────────────────
# Private key of the wallet that will pay for queries (0x-prefixed)
AGENT_PRIVATE_KEY=0xYourAgentPrivateKeyHere

# URL of your deployed worker (after `pnpm deploy:worker`)
WORKER_URL=https://your-worker.your-subdomain.workers.dev

# Blog URL to fetch (agent Phase 1). The agent discovers the
# X-Lemma-Attestation header or <link> meta tag from this URL.
# BLOG_URL=https://your-blog.com/articles/example-article

# ── Circuit Deployment (for forge deploy) ────────────────────────────
# Private key for circuit verifier deployment (with 0x prefix)
PRIVATE_KEY=0x...

# RPC URLs for deployment
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
# Base RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Etherscan API Key for contract verification (works for Ethereum and Base networks)
ETHERSCAN_API_KEY=

# Gas Configuration (optional)
# GAS_PRICE=
# GAS_LIMIT=
