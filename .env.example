# Example-x402 Environment Variables
# Copy this file to .env and fill in your values

# Agent private key (required for real x402 payments)
# Wallet needs Base Sepolia USDC only (gas is paid by facilitator server)
# Get test USDC: https://faucet.circle.com (select Base Sepolia)
AGENT_PRIVATE_KEY=0x...

# Payment recipient address (for deployed worker)
# Set via: npx wrangler secret put PAY_TO_ADDRESS --cwd packages/worker
PAY_TO_ADDRESS=0x...

# Lemma API (pre-configured for demo, optional)
# LEMMA_API_KEY=your_lemma_api_key_here

# Blog URL to verify (optional, defaults to example)
# BLOG_URL=https://example-blog.com/articles/zk-proofs

# Worker URL (local development default)
WORKER_URL=http://localhost:8787
