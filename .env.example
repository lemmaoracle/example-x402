# Example-x402 Integration Environment Variables
# Copy this file to .env and fill in your values

# Lemma API
LEMMA_API_KEY=your_lemma_api_key_here

# Pinata (IPFS) - Optional for circuit registration
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here

# Circuit Details
EXAMPLE_CIRCUIT_ID=example-circuit-v1.2
EXAMPLE_SCHEMA_ID=blog-article-v1

# Verifier Address (from deployment)
EXAMPLE_VERIFIER_ADDRESS=0x354cc716ffc02F57Ff7B0bDd465E9C7f12b785E9

# Network Configuration
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# IPFS URLs (from actual builds)
EXAMPLE_WASM_IPFS=ipfs://QmPipdcWcx7CFXfQDGKpMSJRPyRpcLt4Yqfs1VgvvQ664h
EXAMPLE_ZKEY_IPFS=ipfs://QmWoHWvBKFgYTEZHGGQWK36EMjzcJVycabqmqTKshL3vgT