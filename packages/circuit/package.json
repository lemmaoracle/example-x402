{
  "name": "@example-x402/circuit",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "echo 'Add test script if needed'",
    "forge:build": "forge build",
    "forge:test": "forge test -vvv",
    "forge:clean": "forge clean",
    "forge:deploy": "forge script scripts/Deploy.s.sol --broadcast",
    "forge:deploy:sepolia": "forge script scripts/Deploy.s.sol --rpc-url sepolia --broadcast --verify",
    "forge:deploy:mainnet": "forge script scripts/Deploy.s.sol --rpc-url mainnet --broadcast --verify",
    "forge:deploy:monadTestnet": "forge script scripts/Deploy.s.sol --rpc-url monad_testnet --broadcast --verify",
    "forge:node": "anvil"
  },
  "devDependencies": {
    "circom2": "^0.2.22",
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.5"
  }
}
