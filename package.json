{
  "name": "example-x402",
  "private": true,
  "scripts": {
    "dev:worker": "pnpm --filter @example-x402/worker dev",
    "deploy:worker": "pnpm --filter @example-x402/worker deploy",
    "agent": "pnpm --filter @example-x402/agent start",
    "agent:disclosure": "pnpm --filter @example-x402/agent start -- --with-disclosure",
    "check-balance": "tsx scripts/check-balance.ts",
    "register": "node scripts/register-lemma-artifacts.mjs",
    "register:schema": "tsx scripts/register-schema.ts",
    "register:circuit": "tsx scripts/register-circuit.ts",
    "register:all": "pnpm register:schema && pnpm register:circuit",
    "register:content": "tsx scripts/register-with-full-content.ts",
    "generate-keypair": "tsx scripts/generate-bbs-keypair.ts",
    "generate-snippet": "tsx scripts/generate-snippet.ts"
  },
  "dependencies": {
    "@lemmaoracle/sdk": "0.0.17",
    "@lemmaoracle/spec": "0.0.17",
    "chalk": "^5.6.2",
    "cli-spinners": "^3.4.0",
    "ora": "^9.3.0",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
